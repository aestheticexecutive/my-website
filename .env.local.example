# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/members/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/pricing

# Stripe
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# The price ID for your monthly subscription product
# Create a product + recurring price in Stripe dashboard
STRIPE_PRICE_ID=price_...

# Stripe webhook secret — from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
